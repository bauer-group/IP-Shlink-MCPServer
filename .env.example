# =============================================================================
# Shlink MCP Server — Environment Configuration
# =============================================================================
# Remote MCP server bridging a self-hosted Shlink instance to AI clients
# (Claude Web, Claude Desktop, Microsoft 365 Copilot, ChatGPT, Cursor, ...).
#
# - Inbound (AI client -> MCP):   OAuth 2.1 + PKCE via Entra / Google / OIDC
# - Outbound (MCP -> Shlink):     static X-Api-Key header
#
# /!\ BEFORE FIRST START - replace EVERY value containing "CHANGE_ME" /!\
#
# One-shot, cross-platform (Windows / Linux / macOS):
#
#     python scripts/generate-env.py
#
# Deployment:
#   Local development:   docker compose -f docker-compose.development.yml up -d
#   Self-hosted Traefik: docker compose -f docker-compose.traefik.yml      up -d
#   Coolify:             configure env in dashboard -> docker-compose.coolify.yml
# =============================================================================


# =============================================================================
# Stack Configuration
# =============================================================================

STACK_NAME=bg-shlink-mcp
TIME_ZONE=Etc/UTC

# production | staging | development
# AUTH_MODE=none is only permitted when ENVIRONMENT=development.
ENVIRONMENT=production


# =============================================================================
# Image
# =============================================================================

SHLINK_MCP_IMAGE=ghcr.io/bauer-group/ip-shlink-mcpserver/bg-shlink-mcp
SHLINK_MCP_VERSION=latest

# Redis (OAuth client storage - required in production for restart-safe sessions)
REDIS_IMAGE=redis
REDIS_VERSION=8-alpine

# Redis memory caps - SAFETY LIMITS, not reservations. The actual OAuth
# working set is tiny (a few KB per registered DCR client, plus issued tokens
# - in practice low single-digit MB for a typical BG single-tenant deployment).
# These caps exist to bound runaway growth, not to size the workload.
#
# REDIS_MAXMEMORY        - Redis's internal cap. Combined with the `noeviction`
#                          policy, new writes are refused when reached. Loud
#                          failure beats silent data loss.
# REDIS_CONTAINER_MEM_LIMIT - Hard Docker cgroup limit (defense in depth).
#                          OOM-kills the container if Redis ever exceeds its
#                          own cap due to a bug; restart: unless-stopped
#                          recovers from AOF.
#
# See docs/installation.md for sizing guidance.
REDIS_MAXMEMORY=256mb
REDIS_CONTAINER_MEM_LIMIT=384m


# =============================================================================
# Hostnames & URLs (Traefik / Coolify only)
# =============================================================================

# Public hostname of the MCP server - Let's Encrypt resolves this for HTTPS.
SHLINK_MCP_HOSTNAME=shlink-mcp.example.com

# External Traefik network name (must already exist on the Docker host)
PROXY_NETWORK=EDGEPROXY

# Full public base URL - used in OAuth redirect URIs and protected-resource
# metadata. MUST exactly match what your IdP has registered (case, scheme,
# trailing slash).
PUBLIC_BASE_URL=https://${SHLINK_MCP_HOSTNAME}


# =============================================================================
# Local Ports (development only)
# =============================================================================

SHLINK_MCP_PORT=8000

# Redis port exposure (development convenience - leave empty to keep redis internal)
REDIS_PORT=6379


# =============================================================================
# Shlink Backend (REQUIRED, used for every outbound call)
# =============================================================================
# The MCP server addresses Shlink server-to-server. The API key is the trust
# anchor for that side - it has full read/write authority over the configured
# Shlink instance. Keep it in a secret store; never commit.

# Base URL of your Shlink REST API root (without /rest/v3 - the client adds it).
# Examples:
#   http://shlink:8080                       (same Docker network as Shlink)
#   https://urls.bauer-group.com             (public Shlink instance)
SHLINK_URL=http://shlink:8080

# Shlink API key - generate inside the Shlink container:
#   docker exec shlink shlink api-key:generate --name="mcp-server"
SHLINK_API_KEY=CHANGE_ME_SHLINK_API_KEY

# OpenAPI spec - BUILD-time pin (only used by `docker compose build`).
#
# Sets the Shlink version whose swagger.json gets baked into the image.
# Leave UNSET to inherit the Dockerfile ARG default (currently v5.0.1).
# Setting an empty value here would clobber that default - don't.
#
# Only the development compose file forwards this to docker build; CI and
# the prod compose files use pre-built GHCR images and ignore this var.
# SHLINK_OPENAPI_VERSION=v5.1.0


# OpenAPI spec source - RUNTIME, read by the running container.
#
# Default: file:///app/openapi/shlink.json - the spec is BAKED into the image
# at build time (pinned via the SHLINK_OPENAPI_VERSION build-arg above,
# default v5.0.1). This means:
#   - No outbound HTTP call to GitHub at startup -> faster, air-gapped-safe
#   - A given image tag deterministically produces the same tool surface
#   - Spec upgrades happen via image rebuild, not at runtime
#
# Override when you need a live source (custom fork, version tracking,
# in-house mirror). Examples:
#   SHLINK_OPENAPI_URL=https://raw.githubusercontent.com/shlinkio/shlink/v5.1.0/docs/swagger/swagger.json
#   SHLINK_OPENAPI_URL=file:///custom/path/spec.json   (mount via volume)
SHLINK_OPENAPI_URL=file:///app/openapi/shlink.json

# How often (seconds) to refresh the OpenAPI spec at runtime (0 = never).
# Default 0 matches the baked-in immutable spec - polling a static file is
# pointless. Only set > 0 when SHLINK_OPENAPI_URL points at a MUTABLE remote
# source (e.g. a floating branch, or you want to track upstream patches
# without rebuilding).
SHLINK_OPENAPI_REFRESH_INTERVAL=0

# Per-request timeout to Shlink (seconds)
SHLINK_HTTP_TIMEOUT=30


# =============================================================================
# MCP Server
# =============================================================================

# Transport - only 'streamable-http' makes sense for a remote MCP server.
# 'stdio' is supported for local debugging via Claude Desktop launching the
# binary directly.
MCP_TRANSPORT=streamable-http

# Bind address inside the container. "::" is dual-stack: main.py
# forces IPV6_V6ONLY=0 so one v6 socket accepts both v6 and v4-mapped
# v4 connections. Use "0.0.0.0" to opt out (IPv4-only).
MCP_HOST=::
MCP_PORT=8000

# Log format: console (dev, Rich-coloured) or json (prod, aggregator-friendly)
LOG_FORMAT=json
LOG_LEVEL=INFO


# =============================================================================
# Consent screen branding (OAuth dialog shown to end users)
# =============================================================================
# These three values appear on the FastMCP OAuth consent screen — the dialog
# AI clients (Claude, Microsoft 365 Copilot, ...) render before exchanging the
# first authorization code. Override to rebrand a deployment without forking.
#
# MCP_DISPLAY_NAME   - friendly server name ("...wants to access the MCP server
#                      <name>"). Plain text, NOT the internal identifier.
# MCP_ICON_URL       - absolute URL to the icon. Leave empty to serve the
#                      bundled BAUER GROUP logo at ${PUBLIC_BASE_URL}/logo.svg.
# MCP_WEBSITE_URL    - hyperlink behind the server name. Set to empty to
#                      disable the link.

MCP_DISPLAY_NAME=BAUER GROUP Shlink
MCP_ICON_URL=
MCP_WEBSITE_URL=https://go.bauer-group.com/mcp-server


# =============================================================================
# Auth Mode - pick ONE
# =============================================================================
# Valid: entra-single | entra-multi | google | oidc | none
# 'none' requires ENVIRONMENT=development and prints a loud startup warning.

AUTH_MODE=entra-single


# =============================================================================
# Auth: Microsoft Entra ID - Single Tenant
# =============================================================================
# Quick path (recommended): one-shot provisioning via the helper script -
#   pwsh:   .\scripts\setup-azure-app.ps1 -TenantId <guid> -Hostname mcp.example.com
#   bash:   ./scripts/setup-azure-app.sh  --tenant-id <guid> --hostname mcp.example.com
# Script also supports rotating an expiring secret (--mode rotate-secret).
# Details: docs/authentication.md
#
# Manual path (Portal click-through):
#   1. portal.azure.com -> Entra ID -> App registrations -> New registration
#   2. Single Tenant
#   3. Redirect URI: Web -> ${PUBLIC_BASE_URL}/auth/callback
#   4. API permissions -> Microsoft Graph -> Delegated:
#        email, offline_access, openid, profile  ->  Grant admin consent
#   5. Certificates & secrets -> New client secret -> copy the *value*
#   6. Expose an API -> Application ID URI: api://<client-id> (accept default)
#        -> Add a scope: name=access_as_user, who-can-consent=Admins-and-users
#        -> State: Enabled  ->  Grant admin consent on the new scope
#   7. Manifest -> set "accessTokenAcceptedVersion": 2 (legacy manifest format)
#        or "requestedAccessTokenVersion": 2 (new Microsoft-Graph format) -
#        v2 access tokens carry the scp claim FastMCP validates against

ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=
ENTRA_TENANT_ID=

# Custom API scopes exposed under "Expose an API" - MUST contain at least one
# non-OIDC scope. AzureProvider prefixes them with api://<client_id>/ and
# enforces them on every token. Default matches the step-6 setup above.
# Example for granular auth: ENTRA_API_SCOPES=shlink.read,shlink.write
ENTRA_API_SCOPES=access_as_user

# Upstream-only scopes requested during authorization but NEVER validated -
# put Microsoft Graph delegated permissions here (e.g. User.Read). Leave empty
# unless your tools call Graph via the EntraOBOToken dependency.
ENTRA_EXTRA_SCOPES=


# =============================================================================
# Auth: Microsoft Entra ID - Multi-Tenant
# =============================================================================
# Use when AUTH_MODE=entra-multi.
# ENTRA_TENANT_ID becomes one of:
#   organizations   - accepts work/school accounts from any tenant
#   common          - accepts work/school + personal Microsoft accounts
#
# Without ENTRA_ALLOWED_TENANTS set, *anyone* with a Microsoft account in any
# tenant can call your MCP. Always set the allowlist in production.

ENTRA_ALLOWED_TENANTS=
# Example: ENTRA_ALLOWED_TENANTS=11111111-1111-1111-1111-111111111111,2222...


# =============================================================================
# Auth: Google Workspace
# =============================================================================
# Setup at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: ${PUBLIC_BASE_URL}/auth/callback

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Comma-separated list of Google Workspace domains allowed to authenticate.
# Tokens without a matching `hd` claim are rejected (blocks personal Gmail).
GOOGLE_ALLOWED_DOMAINS=
# Example: GOOGLE_ALLOWED_DOMAINS=bauer-group.com,bauer.com


# =============================================================================
# Auth: Generic OIDC (Authentik / Keycloak / Zitadel / Auth0 / Okta / ...)
# =============================================================================
# Redirect URI: ${PUBLIC_BASE_URL}/auth/callback
#
# Either set OIDC_DISCOVERY_URL and the loader pulls endpoints automatically,
# or set each OIDC_*_URI explicitly. Discovery is preferred - it picks up
# JWKS rotations transparently.

OIDC_DISCOVERY_URL=
# Example: OIDC_DISCOVERY_URL=https://id.bauer-group.com/application/o/shlink-mcp/.well-known/openid-configuration

OIDC_ISSUER=
OIDC_AUTH_URI=
OIDC_TOKEN_URI=
OIDC_JWKS_URI=
OIDC_USERINFO_URI=

OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=

OIDC_SCOPES=openid profile email
OIDC_USERNAME_CLAIM=preferred_username


# =============================================================================
# OAuth Persistence
# =============================================================================
# OAuth state (DCR clients, refresh tokens, auth codes, JTI mappings) must
# survive container restarts — otherwise every client re-registers and every
# user re-authenticates after a deploy.
#
# Two backends, both encrypted at rest:
#   - Redis-backed (recommended for production):
#       AUTH_REDIS_URL=redis://redis:6379/0
#       AUTH_STORAGE_ENCRYPTION_KEY=<fernet-key>   (operator-controlled)
#   - Disk-backed (fallback when no Redis is available):
#       AUTH_REDIS_URL=                            (empty)
#       AUTH_DISK_STORAGE_PATH=/app/data/oauth-storage
#       Encryption key is derived from AUTH_JWT_SIGNING_KEY via HKDF —
#       no separate Fernet key needed. MOUNT THE PATH AS A DOCKER VOLUME,
#       otherwise state is wiped on every container restart.
#
# JWT signing key — used to sign FastMCP-issued tokens AND (in disk mode)
# to derive the storage encryption key. Must survive restarts.
#   openssl rand -hex 32

AUTH_JWT_SIGNING_KEY=CHANGE_ME_AUTH_JWT_SIGNING_KEY

# Redis URL for OAuth client-registration storage. Leave empty to use the
# encrypted disk-storage fallback at AUTH_DISK_STORAGE_PATH.
AUTH_REDIS_URL=redis://redis:6379/0

# Fernet key for at-rest encryption of stored OAuth state in Redis mode.
# REQUIRED when AUTH_REDIS_URL is set; ignored in disk mode (disk-mode
# encryption derives from AUTH_JWT_SIGNING_KEY).
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AUTH_STORAGE_ENCRYPTION_KEY=CHANGE_ME_AUTH_STORAGE_ENCRYPTION_KEY

# Filesystem path for the encrypted disk-storage fallback. Used only when
# AUTH_REDIS_URL is empty. Mount this path as a Docker volume in production
# (the bundled compose files already do this via the `oauth-data` volume).
AUTH_DISK_STORAGE_PATH=/app/data/oauth-storage


# =============================================================================
# Rate Limiting (optional)
# =============================================================================
# Token-bucket limiter applied on every MCP request — the cheapest rejection
# path under load. Keyed per-client when possible:
#   - authenticated requests  -> OAuth subject (`sub` / Entra `oid`)
#   - anonymous requests      -> source IP (X-Forwarded-For, see below)
#   - stdio transport         -> single shared bucket "ip:local"
#
# Defaults express the previous "600 req / 60s" budget as the equivalent
# token-bucket shape: 10 req/s sustained, 20-token burst (≈12 burst+sustained
# bursts feel snappy, then steady-state at 10/s).

RATE_LIMITER_ENABLED=true

# Sustained throughput per client (tokens refilled per second).
RATE_LIMITER_MAX_REQUESTS_PER_SECOND=10

# Maximum burst per client. Leave empty for FastMCP's default of
# 2x max_requests_per_second.
RATE_LIMITER_BURST_CAPACITY=20

# If true, one shared bucket for the WHOLE server (DoS shield only).
# If false (default), one bucket per client identity (fair allocation).
RATE_LIMITER_GLOBAL=false

# Number of trusted reverse-proxy hops in front of this server. Used to
# extract the client IP from X-Forwarded-For — Traefik PREPENDS to XFF, so
# the rightmost value is what the outermost trusted proxy saw (and what we
# can trust). Anything to the left could be a spoofed header set by the
# client itself.
#
#   0  - No proxy. XFF is ignored entirely; request.client.host is used.
#   1  - Direct Traefik / Coolify default. (DEFAULT)
#   2  - Cloudflare -> Traefik. Or any 2-hop edge -> ingress chain.
#   N  - For N trusted proxies in front.
#
# Authenticated requests use the OAuth subject regardless of this setting.
RATE_LIMITER_TRUSTED_PROXY_HOPS=1


# =============================================================================
# Observability
# =============================================================================
# Sentry error tracking (optional - leave SENTRY_DSN empty to disable)

SENTRY_DSN=
SENTRY_ENVIRONMENT=${ENVIRONMENT}
SENTRY_TRACES_SAMPLE_RATE=0.05
